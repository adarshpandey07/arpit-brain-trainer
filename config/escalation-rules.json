{
  "rules": [
    {
      "id": "etsy-api-missing",
      "trigger": "ETSY_API_KEY not set",
      "severity": "critical",
      "message": "ETSY_API_KEY missing! Register at https://www.etsy.com/developers and add key to .env on EC2. Without this, ZERO revenue is possible.",
      "fallbackAction": "build-next-planned",
      "notifyEvery": 6,
      "notifyUnit": "hours"
    },
    {
      "id": "google-auth-failed",
      "trigger": "Google authentication failed",
      "severity": "critical",
      "message": "Google Sheets API auth failed. Check credentials.json on EC2.",
      "fallbackAction": "research",
      "notifyEvery": 6,
      "notifyUnit": "hours"
    },
    {
      "id": "template-build-failed",
      "trigger": "build failed",
      "severity": "warning",
      "message": "Template build failed. Will retry next cycle or skip to next planned template.",
      "fallbackAction": "build-next-planned",
      "notifyEvery": 1,
      "notifyUnit": "cycles"
    },
    {
      "id": "mockup-generation-failed",
      "trigger": "mockup generation failed",
      "severity": "warning",
      "message": "Mockup generation failed. Check SVG templates and sharp/canvas dependency.",
      "fallbackAction": "build-next-planned",
      "notifyEvery": 1,
      "notifyUnit": "cycles"
    },
    {
      "id": "listing-failed",
      "trigger": "listing failed",
      "severity": "high",
      "message": "Etsy listing creation failed. Check API key, OAuth tokens, and rate limits.",
      "fallbackAction": "mockups-next-built",
      "notifyEvery": 2,
      "notifyUnit": "cycles"
    },
    {
      "id": "claude-unavailable",
      "trigger": "Claude unavailable",
      "severity": "warning",
      "message": "Claude Code CLI not responding. Check Max subscription and CLI auth.",
      "fallbackAction": "idle",
      "notifyEvery": 3,
      "notifyUnit": "hours"
    },
    {
      "id": "consecutive-failures",
      "trigger": "consecutive_failures >= 3",
      "severity": "critical",
      "message": "3+ consecutive failures! Brain is stuck. Manual intervention needed.",
      "fallbackAction": "idle",
      "notifyEvery": 1,
      "notifyUnit": "cycles"
    },
    {
      "id": "no-progress-24h",
      "trigger": "no successful action in 24 hours",
      "severity": "high",
      "message": "No successful action in 24 hours. Brain might be stuck in a loop.",
      "fallbackAction": "research",
      "notifyEvery": 24,
      "notifyUnit": "hours"
    }
  ],
  "blockerTracking": {
    "maxBlockerAge": "72h",
    "autoResolveOn": "successful action of same type",
    "reminderInterval": "12h"
  }
}
